# Copie este arquivo para .env e preencha as chaves.
# IMPORTANTE: reinicie o servidor (npm run start:dev) após criar ou alterar o .env.

# Aplicação
NODE_ENV=development
PORT=3000

# API local (C#)
# URL base da API C# usada pelo frontend (ex.: http://localhost:5000)
API_URL=

# Banco de dados (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=pontuaflow_db

# Caminhos (relativos ao root do projeto)
VIEWS_PATH=./views
PUBLIC_PATH=./public
