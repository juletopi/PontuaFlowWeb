<%
  const devsData = Array.isArray(devs) ? devs : [];
  const currentProjectId = typeof projectId !== 'undefined' && projectId ? projectId : '';
%>

<div class="container-lg">
  <div class="row align-items-center mb-4">
    <div class="col">
      <% if (!currentProjectId) { %>
        <div class="alert alert-warning mb-0">Selecione um projeto para cadastrar desenvolvedores com vínculo correto.</div>
      <% } %>
    </div>
    <div class="col-auto">
      <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#devModal">
        <i class="bi bi-plus-circle"></i> Novo Dev
      </button>
    </div>
  </div>

  <div class="card">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Nome</th>
            <th>Cargo</th>
            <th>E-mail</th>
            <th>Data de Início</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (devsData.length > 0) { %>
            <% devsData.forEach(dev => { %>
              <tr>
                <td><%= dev.name %></td>
                <td><%= dev.role %></td>
                <td><%= dev.email || '-' %></td>
                <td><%= dev.startDate ? new Date(dev.startDate).toLocaleDateString('pt-BR') : '-' %></td>
                <td>
                  <div class="d-flex gap-2">
                    <button
                      class="btn btn-sm btn-outline-secondary edit-dev-btn"
                      type="button"
                      data-dev-id="<%= dev.id %>"
                      data-dev-name="<%= dev.name %>"
                      data-dev-role="<%= dev.role %>"
                      data-dev-email="<%= dev.email || '' %>"
                      data-dev-start-date="<%= dev.startDate || '' %>"
                    >
                      Editar
                    </button>
                    <button
                      class="btn btn-sm btn-outline-danger delete-dev-btn"
                      type="button"
                      data-dev-id="<%= dev.id %>"
                      data-dev-name="<%= dev.name %>"
                    >
                      Excluir
                    </button>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="5" class="text-center text-muted py-4">
                <i class="bi bi-inbox"></i> Nenhum desenvolvedor cadastrado
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="modal fade" id="devDeleteModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Excluir Desenvolvedor</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p class="mb-2">Tem certeza que deseja excluir este desenvolvedor?</p>
        <p class="fw-semibold mb-0" id="devDeleteLabel"></p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-danger" id="confirmDevDeleteButton">Excluir</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="devModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="devModalTitle">Novo Desenvolvedor</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="devForm">
        <div class="modal-body">
          <div class="mb-3">
            <label for="devName" class="form-label">Nome</label>
            <input type="text" class="form-control" id="devName" required>
          </div>
          <div class="mb-3">
            <label for="devRole" class="form-label">Cargo</label>
            <input type="text" class="form-control" id="devRole" placeholder="ex: Backend Developer">
          </div>
          <div class="mb-3">
            <label for="devEmail" class="form-label">E-mail (opcional)</label>
            <input type="email" class="form-control" id="devEmail">
          </div>
          <div class="mb-3">
            <label for="devStartDate" class="form-label">Data de Início (opcional)</label>
            <input type="date" class="form-control" id="devStartDate">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary" id="devSubmitButton">Adicionar Dev</button>
        </div>
      </form>
    </div>
  </div>
</div>

<style>
  .table {
    margin-bottom: 0;
  }

</style>

<script>
  $(function() {
    const projectId = '<%= currentProjectId %>';
    const devModalElement = document.getElementById('devModal');
    const devModal = bootstrap.Modal.getOrCreateInstance(devModalElement);
    const devDeleteModalElement = document.getElementById('devDeleteModal');
    const devDeleteModal = bootstrap.Modal.getOrCreateInstance(devDeleteModalElement);
    let editingDevId = null;
    let deletingDevId = null;

    const readApiError = async (response) => {
      try {
        const contentType = response.headers.get('content-type') || '';

        if (contentType.includes('application/json')) {
          const data = await response.json();
          return data.detail || data.title || data.message || JSON.stringify(data);
        }

        const text = await response.text();
        return text || 'Falha desconhecida na API';
      } catch {
        return 'Falha desconhecida na API';
      }
    };

    const resetDevForm = () => {
      editingDevId = null;
      $('#devModalTitle').text('Novo Desenvolvedor');
      $('#devSubmitButton').text('Adicionar Dev');
      $('#devForm')[0].reset();
    };

    $('.edit-dev-btn').on('click', function() {
      const button = $(this);

      editingDevId = button.data('dev-id');

      $('#devModalTitle').text('Editar Desenvolvedor');
      $('#devSubmitButton').text('Salvar Alterações');
      $('#devName').val(button.data('dev-name') || '');
      $('#devRole').val(button.data('dev-role') || '');
      $('#devEmail').val(button.data('dev-email') || '');
      $('#devStartDate').val((button.data('dev-start-date') || '').toString().slice(0, 10));
      devModal.show();
    });

    $('.delete-dev-btn').on('click', function() {
      const button = $(this);
      deletingDevId = button.data('dev-id');
      $('#devDeleteLabel').text(button.data('dev-name') || 'Desenvolvedor selecionado');
      devDeleteModal.show();
    });

    $('#confirmDevDeleteButton').on('click', async function() {
      if (!deletingDevId) {
        return;
      }

      const submitButton = $(this);
      const url = `/api/projects/${projectId}/devs/${deletingDevId}`;

      submitButton.prop('disabled', true);

      try {
        const response = await fetch(url, { method: 'DELETE' });

        if (!response.ok) {
          throw new Error(await readApiError(response));
        }

        window.location.reload();
      } catch (error) {
        alert(`Não foi possível excluir o desenvolvedor. ${error.message || 'Verifique a API e tente novamente.'}`);
      } finally {
        submitButton.prop('disabled', false);
      }
    });

    $('#devModal').on('hidden.bs.modal', resetDevForm);
    $('#devDeleteModal').on('hidden.bs.modal', function() {
      deletingDevId = null;
      $('#devDeleteLabel').text('');
    });

    $('#devForm').on('submit', async function(e) {
      e.preventDefault();

      if (!projectId) {
        alert('Selecione um projeto antes de cadastrar desenvolvedores.');
        return;
      }

      const payload = {
        ...(editingDevId ? { Id: Number(editingDevId) } : {}),
        ProjectId: Number(projectId),
        Nome: $('#devName').val().trim(),
        Cargo: $('#devRole').val().trim(),
        Email: $('#devEmail').val().trim() || null,
        DataInicio: $('#devStartDate').val() || null,
      };

      const method = editingDevId ? 'PUT' : 'POST';
      const url = editingDevId ? `/api/projects/${projectId}/devs/${editingDevId}` : `/api/projects/${projectId}/devs`;

      try {
        const response = await fetch(url, {
          method,
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(payload),
        });

        if (!response.ok) {
          throw new Error(await readApiError(response));
        }

        window.location.reload();
      } catch (error) {
        alert(`Não foi possível salvar o desenvolvedor. ${error.message || 'Verifique a API e tente novamente.'}`);
      }
    });
  });
</script>
