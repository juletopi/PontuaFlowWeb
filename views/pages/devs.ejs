<% var inProject = true; var backUrl = '/'; %>

<div class="container-lg">
  <div class="row align-items-center mb-4">
    <div class="col">
      <!-- Título renderizado pelo layout -->
    </div>
    <div class="col-auto">
      <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#devModal">
        <i class="bi bi-plus-circle"></i> Novo Dev
      </button>
    </div>
  </div>

  <div class="card">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Nome</th>
            <th>Cargo</th>
            <th>E-mail</th>
            <th>Data de Início</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td colspan="5" class="text-center text-muted py-4">
              <i class="bi bi-inbox"></i> Nenhum desenvolvedor cadastrado
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="modal fade" id="devModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Novo Desenvolvedor</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="devForm">
        <div class="modal-body">
          <div class="mb-3">
            <label for="devName" class="form-label">Nome</label>
            <input type="text" class="form-control" id="devName" required>
          </div>
          <div class="mb-3">
            <label for="devRole" class="form-label">Cargo</label>
            <input type="text" class="form-control" id="devRole" placeholder="ex: Backend Developer">
          </div>
          <div class="mb-3">
            <label for="devEmail" class="form-label">E-mail (opcional)</label>
            <input type="email" class="form-control" id="devEmail">
          </div>
          <div class="mb-3">
            <label for="devStartDate" class="form-label">Data de Início (opcional)</label>
            <input type="date" class="form-control" id="devStartDate">
          </div>
          <div class="mb-3">
            <label for="devAvatar" class="form-label">Avatar (opcional)</label>
            <input type="file" class="form-control" id="devAvatar" accept="image/*">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary">Adicionar Dev</button>
        </div>
      </form>
    </div>
  </div>
</div>

<style>
  .table {
    margin-bottom: 0;
  }

  .dark-mode .table-light {
    background-color: #374151;
  }

  .dark-mode .table {
    color: #f3f4f6;
    border-color: #374151;
  }

  .dark-mode .table tbody tr:hover {
    background-color: #2d3748;
  }
</style>

<script>
  $(function() {
    $('#devForm').on('submit', function(e) {
      e.preventDefault();
      alert('Funcionalidade em desenvolvimento');
    });
  });
</script>
