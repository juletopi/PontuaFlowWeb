<%
  const currentProject = typeof project !== 'undefined' ? project : null;
  const summaryData = typeof summary !== 'undefined' && summary
    ? summary
    : { totalDevs: 0, totalTasks: 0, totalPoints: 0, averagePerformance: 0 };
  const rankingData = Array.isArray(ranking) ? ranking : [];
  const tasksData = Array.isArray(tasks) ? tasks : [];
  const homeActionsBase = typeof projectId !== 'undefined' && projectId ? `/project/${projectId}` : '';
  const resumeHref = homeActionsBase || '/home';
  const metricsHref = homeActionsBase ? `${homeActionsBase}/metrics` : '/metrics';
  const tasksHref = homeActionsBase ? `${homeActionsBase}/tasks` : '/tasks';
%>

<div class="container-lg">
  <% if (currentProject) { %>
    <div class="alert alert-primary border-0 mb-4 shadow-sm">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
          <h5 class="mb-1"><%= currentProject.name %></h5>
          <p class="mb-0"><%= currentProject.description || 'Sem descrição cadastrada para este projeto.' %></p>
        </div>
        <div class="d-flex gap-2">
          <a class="btn btn-sm btn-outline-primary" href="<%= resumeHref %>">Resumo</a>
          <a class="btn btn-sm btn-outline-primary" href="<%= metricsHref %>">Métricas</a>
          <a class="btn btn-sm btn-outline-primary" href="<%= tasksHref %>">Tarefas</a>
        </div>
      </div>
    </div>
  <% } %>

  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <p class="card-text text-muted small">Total de Devs</p>
              <h3 class="h2 mb-0"><%= summaryData.totalDevs || 0 %></h3>
            </div>
            <i class="bi bi-people-fill text-primary" style="font-size: 2rem;"></i>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <p class="card-text text-muted small">Total de Tarefas</p>
              <h3 class="h2 mb-0"><%= summaryData.totalTasks || 0 %></h3>
            </div>
            <i class="bi bi-list-check text-success" style="font-size: 2rem;"></i>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <p class="card-text text-muted small">Total de Pontos</p>
              <h3 class="h2 mb-0"><%= summaryData.totalPoints || 0 %></h3>
            </div>
            <i class="bi bi-star-fill text-warning" style="font-size: 2rem;"></i>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <p class="card-text text-muted small">Aproveitamento Médio</p>
              <h3 class="h2 mb-0"><%= Math.round(summaryData.averagePerformance || 0) %>%</h3>
            </div>
            <i class="bi bi-graph-up text-info" style="font-size: 2rem;"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="tab-content">
    <div class="tab-pane fade show active" id="resume" role="tabpanel">
      <div class="card">
        <div class="card-body">
          <% if (tasksData.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Tarefa</th>
                    <th>Dev</th>
                    <th>Pontos</th>
                    <th>Semana</th>
                  </tr>
                </thead>
                <tbody>
                  <% tasksData.slice(0, 5).forEach(task => { %>
                    <tr>
                      <td>
                        <strong><%= task.title %></strong>
                        <% if (task.description) { %>
                          <div class="text-muted small"><%= task.description %></div>
                        <% } %>
                      </td>
                      <td><%= task.devName || 'Sem vínculo' %></td>
                      <td><%= task.points || 0 %></td>
                      <td><%= task.weekNumber || '-' %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <p class="text-muted mb-0">Nenhuma tarefa disponível para resumir ainda.</p>
          <% } %>
        </div>
      </div>
    </div>

    <div class="tab-pane fade" id="devs" role="tabpanel">
      <div class="card">
        <div class="card-body">
          <% if (Array.isArray(devs) && devs.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Nome</th>
                    <th>Cargo</th>
                    <th>E-mail</th>
                  </tr>
                </thead>
                <tbody>
                  <% devs.slice(0, 5).forEach(dev => { %>
                    <tr>
                      <td><%= dev.name %></td>
                      <td><%= dev.role %></td>
                      <td><%= dev.email || '-' %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <p class="text-muted mb-0">Nenhum desenvolvedor disponível ainda.</p>
          <% } %>
        </div>
      </div>
    </div>

    <div class="tab-pane fade" id="tasks" role="tabpanel">
      <div class="card">
        <div class="card-body">
          <% if (tasksData.length > 0) { %>
            <ul class="list-group list-group-flush">
              <% tasksData.slice(0, 5).forEach(task => { %>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                  <div>
                    <strong><%= task.title %></strong>
                    <div class="text-muted small"><%= task.devName || 'Sem vínculo' %></div>
                  </div>
                  <span class="badge bg-primary rounded-pill"><%= task.points || 0 %> pts</span>
                </li>
              <% }) %>
            </ul>
          <% } else { %>
            <p class="text-muted mb-0">Nenhuma tarefa cadastrada para este contexto.</p>
          <% } %>
        </div>
      </div>
    </div>

    <div class="tab-pane fade" id="metrics" role="tabpanel">
      <div class="card">
        <div class="card-body">
          <% if (rankingData.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Posição</th>
                    <th>Nome</th>
                    <th>Pontos</th>
                    <th>Aproveitamento</th>
                  </tr>
                </thead>
                <tbody>
                  <% rankingData.slice(0, 5).forEach((item, index) => { %>
                    <tr>
                      <td><%= index + 1 %></td>
                      <td><%= item.name %></td>
                      <td><%= item.totalPoints || 0 %></td>
                      <td><%= Math.round(item.performance || 0) %>%</td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <p class="text-muted mb-0">As métricas aparecem aqui quando a API retornar o ranking do projeto.</p>
          <% } %>
        </div>
      </div>
    </div>

    <div class="tab-pane fade" id="settings" role="tabpanel">
      <div class="card">
        <div class="card-body">
          <p class="text-muted mb-0">As configurações ficam agrupadas nesta área, mas a navegação já preserva o contexto do projeto.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .card {
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
  }

  .dark-mode .card {
    background-color: #2d3748;
    border-color: #374151;
  }

  .dark-mode .card-text {
    color: #9ca3af !important;
  }

  .tab-content {
    margin-top: 1.5rem;
  }
</style>
