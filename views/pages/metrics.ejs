<% var inProject = true; var backUrl = '/'; %>

<div class="container-lg">

  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <div class="card">
        <div class="card-body">
          <h5 class="card-title">Total de Pontos</h5>
          <h3 class="h1 text-primary">0</h3>
          <p class="text-muted small">Soma de todas as pontuações</p>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card">
        <div class="card-body">
          <h5 class="card-title">Aproveitamento Geral</h5>
          <h3 class="h1 text-success">0%</h3>
          <p class="text-muted small">Média de aproveitamento dos devs</p>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <h5 class="mb-0">Ranking de Desenvolvedores</h5>
    </div>
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th style="width: 50px;">Posição</th>
            <th>Nome</th>
            <th>Cargo</th>
            <th>Total de Pontos</th>
            <th>Aproveitamento</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td colspan="5" class="text-center text-muted py-4">
              <i class="bi bi-inbox"></i> Nenhum desenvolvedor para exibir
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<style>
  .card-header {
    background-color: #f9fafb;
    border-bottom: 1px solid #e5e7eb;
    padding: 1rem 1.25rem;
  }

  .dark-mode .card-header {
    background-color: #1f2937;
    border-bottom-color: #374151;
  }

  .table {
    margin-bottom: 0;
  }

  .dark-mode .table-light {
    background-color: #374151;
  }

  .dark-mode .table {
    color: #f3f4f6;
    border-color: #374151;
  }

  .dark-mode .table tbody tr:hover {
    background-color: #2d3748;
  }
</style>
