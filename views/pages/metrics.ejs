<%
  const summaryData = typeof summary !== 'undefined' && summary
    ? summary
    : { totalDevs: 0, totalTasks: 0, totalPoints: 0, averagePerformance: 0 };
  const rankingData = Array.isArray(ranking) ? ranking : [];
%>

<div class="container-lg">

  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <div class="card">
        <div class="card-body">
          <h5 class="card-title">Total de Pontos</h5>
          <h3 class="h1 text-primary"><%= summaryData.totalPoints || 0 %></h3>
          <p class="text-muted small">Soma de todas as pontuações</p>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card">
        <div class="card-body">
          <h5 class="card-title">Aproveitamento Geral</h5>
          <h3 class="h1 text-success"><%= Math.round(summaryData.averagePerformance || 0) %>%</h3>
          <p class="text-muted small">Média de aproveitamento dos devs</p>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <h5 class="mb-0">Ranking de Desenvolvedores</h5>
    </div>
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th style="width: 50px;">Posição</th>
            <th>Nome</th>
            <th>Cargo</th>
            <th>Total de Pontos</th>
            <th>Aproveitamento</th>
          </tr>
        </thead>
        <tbody>
          <% if (rankingData.length > 0) { %>
            <% rankingData.forEach((item, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td><%= item.name %></td>
                <td><%= item.role || '-' %></td>
                <td><%= item.totalPoints || 0 %></td>
                <td><%= Math.round(item.performance || 0) %>%</td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="5" class="text-center text-muted py-4">
                <i class="bi bi-inbox"></i> Nenhum desenvolvedor para exibir
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<style>
  .card-header {
    background-color: #f9fafb;
    border-bottom: 1px solid #e5e7eb;
    padding: 1rem 1.25rem;
  }

  .table {
    margin-bottom: 0;
  }
</style>
