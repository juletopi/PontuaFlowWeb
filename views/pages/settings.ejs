<%
  const currentProject = typeof project !== 'undefined' ? project : null;
  const summaryData = typeof summary !== 'undefined' && summary
    ? summary
    : { totalDevs: 0, totalTasks: 0, totalPoints: 0, averagePerformance: 0 };
%>

<div class="container-lg">

  <div class="row">
    <div class="col-md-6">
      <div class="card">
        <div class="card-header">
          <h5 class="mb-0">Projeto</h5>
        </div>
        <div class="card-body">
          <% if (currentProject) { %>
            <p class="text-muted small mb-2">Projeto atual</p>
            <h6 class="mb-3"><%= currentProject.name %></h6>
            <p class="text-muted small"><%= currentProject.description || 'Sem descrição cadastrada.' %></p>
            <hr>
          <% } %>

          <p class="text-muted small mb-2">Resumo da integração</p>
          <ul class="list-unstyled mb-0">
            <li class="mb-2"><strong>Devs:</strong> <%= summaryData.totalDevs || 0 %></li>
            <li class="mb-2"><strong>Tarefas:</strong> <%= summaryData.totalTasks || 0 %></li>
            <li class="mb-2"><strong>Pontos:</strong> <%= summaryData.totalPoints || 0 %></li>
            <li><strong>Aproveitamento médio:</strong> <%= Math.round(summaryData.averagePerformance || 0) %>%</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card">
        <div class="card-header">
          <h5 class="mb-0">Sobre</h5>
        </div>
        <div class="card-body">
          <p>
            <strong>PontuaFlow Web</strong><br>
            v0.1.0
          </p>
          <p class="text-muted small">
            Sistema de gestão e pontuação de desenvolvedores em projetos.
          </p>
          <hr>
          <p class="text-muted small">
            <i class="bi bi-info-circle"></i>
            Desenvolvido com NestJS, TypeScript, EJS e Bootstrap.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .card-header {
    background-color: #f9fafb;
    border-bottom: 1px solid #e5e7eb;
    padding: 1rem 1.25rem;
  }

  .dark-mode .card-header {
    background-color: #1f2937;
    border-bottom-color: #374151;
  }

  .dark-mode .card {
    background-color: #2d3748;
    border-color: #374151;
  }

  .form-check-label {
    cursor: pointer;
    margin-left: 0.25rem;
  }
</style>

<script>
  $(function() {
    const applySavedTheme = () => {
      const savedTheme = localStorage.getItem('theme') || 'auto';
      const themeId = `theme${savedTheme.charAt(0).toUpperCase() + savedTheme.slice(1)}`;

      $(`input[name="theme"]`).prop('checked', false);
      $(`#${themeId}`).prop('checked', true);
      updateTheme(savedTheme);

      const savedColorScheme = localStorage.getItem('colorScheme');

      if (savedColorScheme) {
        $('#colorScheme').val(savedColorScheme);
      }
    };

    $('input[name="theme"]').on('change', function() {
      const theme = $(this).val();
      localStorage.setItem('theme', theme);
      updateTheme(theme);
    });

    $('#colorScheme').on('change', function() {
      const scheme = $(this).val();
      localStorage.setItem('colorScheme', scheme);
    });

    applySavedTheme();
  });

  const updateTheme = (theme) => {
    if (theme === 'auto') {
      if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
        document.body.classList.add('dark-mode');
      } else {
        document.body.classList.remove('dark-mode');
      }
    } else if (theme === 'dark') {
      document.body.classList.add('dark-mode');
    } else {
      document.body.classList.remove('dark-mode');
    }
  };
</script>
